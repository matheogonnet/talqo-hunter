# ------- Supabase -------
# Trouvé dans : Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ------- Claude API (Anthropic) -------
# Trouvé dans : https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ------- Resend (email) -------
# Trouvé dans : https://resend.com/api-keys
RESEND_API_KEY=re_...
# L'email qui reçoit les notifications de nouveaux prospects
NOTIFICATION_EMAIL=matheo@example.com

# ------- Sécurité Cron -------
